# OpenClaude .dockerignore
# Prevents unnecessary files from being copied into Docker image

# Node modules and package manager caches (will be installed in container)
node_modules
.npm
.yarn
.bun

# Build output (will be built in container)
dist
build
*.tsbuildinfo

# Development files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Git
.git
.gitignore
.gitattributes

# CI/CD
.github
.gitlab-ci.yml

# Documentation (except README)
docs
*.md
!README.md

# Test files
*.test.ts
*.test.js
*.spec.ts
*.spec.js
__tests__
coverage
.nyc_output

# Environment files (should be provided via docker-compose or Coolify)
.env
.env.*
!.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs
lib-cov

# Coverage directory
coverage
.coverage

# Temporary files
tmp
temp
*.tmp

# OS files
Thumbs.db
.DS_Store
.Spotlight-V100
.Trashes

# IDE files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.idea
*.iml
.project
.classpath
.settings

# Docker files (no need to copy into image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Deployment files (not needed in container)
DEPLOYMENT.md

# Reports and diagnostics
reports

# User data (will be mounted as volume)
.openclaude-profile.json

# Python cache (if any)
__pycache__
*.py[cod]
*$py.class
*.so

# Optional: Scripts that are only for local development
scripts/provider-*.ts
scripts/system-check.ts

# Bun lockfile (already copied separately)
# bun.lock