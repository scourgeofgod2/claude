# OpenClaude Environment Variables
# Copy this file to .env and fill in your values
# Or set these in Coolify UI under Environment Variables

# ============================================================================
# Core Settings
# ============================================================================

# Always set to 1 to use OpenAI-compatible providers
CLAUDE_CODE_USE_OPENAI=1

# Node environment
NODE_ENV=production

# Timezone (optional)
TZ=UTC


# ============================================================================
# OpenAI Provider (Default)
# ============================================================================

# Your OpenAI API key
OPENAI_API_KEY=sk-your-openai-key-here

# Model to use
OPENAI_MODEL=gpt-4o

# API endpoint (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1


# ============================================================================
# Codex Provider (ChatGPT Backend)
# ============================================================================

# Use codexplan or codexspark
# OPENAI_MODEL=codexplan

# Codex API key (or use ~/.codex/auth.json)
# CODEX_API_KEY=your-codex-token-here

# Path to Codex auth file (optional)
# CODEX_AUTH_JSON_PATH=/root/.codex/auth.json

# Codex home directory (optional)
# CODEX_HOME=/root/.codex


# ============================================================================
# DeepSeek Provider
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat


# ============================================================================
# Google Gemini (via OpenRouter)
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=sk-or-your-openrouter-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=google/gemini-2.0-flash


# ============================================================================
# Ollama (Local)
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_MODEL=llama3.3:70b
# No API key needed for local models


# ============================================================================
# LM Studio (Local)
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# OPENAI_MODEL=your-model-name
# No API key needed for local models


# ============================================================================
# Together AI
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=your-together-api-key
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo


# ============================================================================
# Groq
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=gsk-your-groq-key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile


# ============================================================================
# Mistral AI
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=your-mistral-key
# OPENAI_BASE_URL=https://api.mistral.ai/v1
# OPENAI_MODEL=mistral-large-latest


# ============================================================================
# Azure OpenAI
# ============================================================================

# CLAUDE_CODE_USE_OPENAI=1
# OPENAI_API_KEY=your-azure-key
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/v1
# OPENAI_MODEL=gpt-4o


# ============================================================================
# Advanced Settings (Optional)
# ============================================================================

# Override model selection (OPENAI_MODEL takes priority)
# ANTHROPIC_MODEL=gpt-4o

# Additional provider-specific settings can be added here